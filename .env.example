# Supabase Credentials (Get these from your project settings -> API)
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Prisma Database Connections (Get these from project settings -> Database)
# Use the "Transaction Mode" URL for DATABASE_URL (usually port 6543)
# Use the "Session Mode" or Direct connection for DIRECT_URL (usually port 5432)
DATABASE_URL="postgresql://postgres.your-project:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.your-project:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
